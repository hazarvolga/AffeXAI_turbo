{
	"name": "@affex/starter-nest",
	"version": "0.1.0",
	"private": true,
	"description": "Layer 1 reference NestJS app wiring all @affex/*-core packages",
	"main": "./dist/main.js",
	"scripts": {
		"build": "nest build",
		"dev": "nest start --watch",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@nestjs/common": "^10.4.15",
		"@nestjs/config": "^3.3.0",
		"@nestjs/core": "^10.4.15",
		"@nestjs/platform-express": "^10.4.15",
		"@affex/ai-core": "workspace:*",
		"@affex/auth-core": "workspace:*",
		"@affex/db-core": "workspace:*",
		"@affex/observability-core": "workspace:*",
		"@affex/queue-core": "workspace:*",
		"@affex/shared-config": "workspace:*",
		"@affex/shared-types": "workspace:*",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.1"
	},
	"devDependencies": {
		"@nestjs/cli": "^10.4.9",
		"@nestjs/schematics": "^10.2.3",
		"@nestjs/testing": "^10.4.15",
		"@types/express": "^5.0.0",
		"ts-node": "^10.9.2",
		"typescript": "^5.7.3",
		"vitest": "^2.1.8"
	},
	"layer": "ACTIVE_NOW"
}
