{
  "name": "@affex/shared-types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared Zod schemas and TypeScript types for affexaiFactory",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./user": "./src/user.ts",
    "./api": "./src/api.ts",
    "./auth": "./src/auth.ts"
  },
  "scripts": {
