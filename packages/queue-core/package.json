{
	"name": "@affex/queue-core",
	"version": "0.1.0",
	"private": true,
	"description": "BullMQ typed wrapper with job factories and DLQ for the affexaiFactory monorepo",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./types": "./src/types.ts",
		"./factory": "./src/factory.ts",
		"./dlq": "./src/dlq.ts",
		"./nestjs": "./src/queue.module.ts"
	},
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"test": "vitest run --passWithNoTests",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"bullmq": "^5.34.8",
		"ioredis": "^5.4.2"
	},
	"peerDependencies": {
		"@nestjs/common": "^10.0.0",
		"@nestjs/core": "^10.0.0"
	},
	"peerDependenciesMeta": {
		"@nestjs/common": { "optional": true },
		"@nestjs/core": { "optional": true }
	},
	"devDependencies": {
		"@nestjs/common": "^10.4.15",
		"@nestjs/core": "^10.4.15",
		"typescript": "^5.7.3",
		"vitest": "^2.1.8"
	},
	"layer": "ACTIVE_NOW"
}
