{
	"name": "@affex/ai-core",
	"version": "0.1.0",
	"private": true,
	"description": "Multi-provider LLM client with retry, caching, and Langfuse tracing",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./providers/openai": "./src/providers/openai.js",
		"./providers/anthropic": "./src/providers/anthropic.js",
		"./providers/ollama": "./src/providers/ollama.js",
		"./retry": "./src/retry.js",
		"./cache": "./src/cache.js",
		"./langfuse": "./src/langfuse.js",
		"./client": "./src/client.js"
	},
	"scripts": {
		"build": "tsc --project tsconfig.json",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"test": "vitest run --passWithNoTests",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.39.0",
		"langfuse": "^3.29.1",
		"openai": "^4.77.0"
	},
	"devDependencies": {
		"typescript": "^5.7.3",
		"vitest": "^2.1.8"
	},
	"layer": "ACTIVE_NOW"
}