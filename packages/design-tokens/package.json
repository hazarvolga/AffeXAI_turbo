{
  "name": "@affex/design-tokens",
  "version": "0.1.0",
  "private": true,
  "description": "Design tokens - Tailwind preset, CSS variables, and font config",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tailwind": "./tailwind/preset.ts",
    "./css": "./css/variables.css"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tailwind/ css/",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "layer": "ACTIVE_NOW"
}