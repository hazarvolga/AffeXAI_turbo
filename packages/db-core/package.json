{
  "name": "@affex/db-core",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma client factory, soft-delete middleware, audit log middleware, and migration helpers",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./soft-delete": "./src/soft-delete.ts",
    "./audit-log": "./src/audit-log.ts",
    "./migrations": "./src/migrations.ts"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "test": "vitest run --passWithNoTests",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "layer": "ACTIVE_NOW"
}