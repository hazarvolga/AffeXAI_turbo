{
	"name": "affexai-factory",
	"version": "0.0.0",
	"private": true,
	"description": "Solo Founder Engineering OS — Monorepo factory for AI-first development",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint:fix": "biome lint --write .",
		"check": "biome check --write .",
		"clean": "turbo run clean && rimraf node_modules",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "turbo run build --filter=./packages/* && changeset publish",
		"doctor": "node tools/doctor/src/index.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@changesets/cli": "^2.27.11",
		"rimraf": "^6.0.1",
		"turbo": "^2.3.3",
		"typescript": "^5.7.3",
		"vitest": "^2.1.8"
	},
	"packageManager": "pnpm@9.15.4",
	"engines": {
		"node": ">=22.0.0"
	}
}
