{
	"name": "migrate-repo",
	"version": "0.1.0",
	"private": true,
	"description": "CLI tool for migrating existing repos into affexaiFactory",
	"type": "module",
	"bin": {
		"migrate-repo": "./dist/index.js"
	},
	"main": "./dist/index.js",
	"scripts": {
		"build": "tsc",
		"dev": "tsx src/index.ts",
		"test": "vitest run --passWithNoTests",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src/",
		"clean": "rimraf dist"
	},
	"dependencies": {
		"chalk": "^5.3.0",
		"commander": "^12.1.0",
		"fs-extra": "^11.2.0",
		"glob": "^10.3.10",
		"simple-git": "^3.27.0"
	},
	"devDependencies": {
		"@types/fs-extra": "^11.0.4",
		"tsx": "^4.19.0",
		"typescript": "^5.7.3",
		"vitest": "^2.1.8"
	},
	"layer": "OPTIONAL_LATER"
}
