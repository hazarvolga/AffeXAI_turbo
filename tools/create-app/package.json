{
	"name": "create-app",
	"version": "0.1.0",
	"private": true,
	"description": "Project scaffolding CLI for @affex/* apps",
	"bin": {
		"create-app": "./dist/index.js"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
